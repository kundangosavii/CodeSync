---
const { headings } = Astro.props;

// Filter to only display major sections (H2 and H3)
const filteredHeadings = headings?.filter((h) => h.depth === 2 || h.depth === 3) || [];
---

<aside class="hidden xl:block w-64 shrink-0 sticky top-14 h-[calc(100vh-3.5rem)] overflow-y-auto pt-8 pl-6">
  {filteredHeadings.length > 0 && (
    <div class="space-y-4">
      <h4 class="text-xs font-semibold tracking-wider text-zinc-400 dark:text-zinc-500 uppercase">
        On This Page
      </h4>
      <ul class="space-y-2.5 text-sm border-l border-zinc-200 dark:border-zinc-800">
        {filteredHeadings.map((heading) => (
          <li class={`-ml-px border-l ${heading.depth === 3 ? 'pl-6' : 'pl-4'} border-transparent`}>
            <a 
              href={`#${heading.slug}`} 
              class="block text-zinc-500 dark:text-zinc-400 hover:text-orange-500 dark:hover:text-orange-400 transition-colors line-clamp-2 leading-relaxed"
            >
              {heading.text}
            </a>
          </li>
        ))}
      </ul>
    </div>
  )}
</aside>