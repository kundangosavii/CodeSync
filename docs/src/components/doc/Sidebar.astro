---
import { getCollection } from 'astro:content';

const currentPath = Astro.url.pathname;
const docs = await getCollection('docs');


const SECTION_ORDER = [
  'getting-started',
  'cli',
  'dashboard',
  'core-features',
];


const groupedDocs = docs.reduce((acc, doc) => {
  const parts = doc.id.split('/');
  
  const section = parts.length > 1 ? parts[0] : 'getting-started';

  if (!acc[section]) {
    acc[section] = [];
  }
  acc[section].push(doc);
  return acc;
}, {} as Record<string, typeof docs>);


const sortedSections = Object.keys(groupedDocs).sort((a, b) => {
  const indexA = SECTION_ORDER.indexOf(a);
  const indexB = SECTION_ORDER.indexOf(b);

  
  const orderA = indexA === -1 ? 999 : indexA;
  const orderB = indexB === -1 ? 999 : indexB;

  return orderA - orderB;
});


const formatTitle = (str: string) => {
  return str.replace(/-/g, ' ').replace(/\b\w/g, (char) => char.toUpperCase());
};
---

<aside class="w-64 shrink-0 pr-6 py-8 border-r mt-14 border-zinc-200 dark:border-zinc-800">
  <nav class="space-y-6">
    {sortedSections.map((section) => {
      const items = groupedDocs[section];

     
      items.sort((a, b) => (a.data.order || 99) - (b.data.order || 99));

      return (
        <div>
         
          <h3 class="text-2xs font-semibold tracking-wider text-black dark:text-white uppercase mb-3 px-3">
            {formatTitle(section)}
          </h3>

          
          <ul class="space-y-1">
            {items.map((doc) => {
              const href = `/docs/${doc.id}`;
              const isActive = currentPath === href || currentPath === `${href}/`;

              return (
                <li>
                  <a
                    href={href}
                    class:list={[
                      "block px-3 py-1.5 text-sm rounded-lg transition-colors font-medium",
                      isActive
                        ? "bg-orange-500/10 text-orange-500 font-semibold"
                        : "text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-200 hover:bg-zinc-100 dark:hover:bg-zinc-800/50"
                    ]}
                  >
                    {doc.data.title || formatTitle(doc.id.split('/').pop() || '')}
                  </a>
                </li>
              );
            })}
          </ul>
        </div>
      );
    })}
  </nav>
</aside>